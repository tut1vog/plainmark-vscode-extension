+        let cjkBefore = cjkAdjacentBefore(cx, start), cjkAfter = cjkAdjacentAfter(cx, pos);
+        let leftFlanking = !sAfter && (!pAfter || sBefore || pBefore || cjkAfter || cjkBefore || ideographicVSBefore(cx, start));
